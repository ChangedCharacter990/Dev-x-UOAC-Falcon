{
  "manifest_version": 3,
  "name": "Net Worth Predictor",
  "version": "0.1.0",
  "description": "Predicts your future net worth. Watch it drop every time you scroll a short.",
  "permissions": ["storage","tabs"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://www.tiktok.com/*",
        "*://www.instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
